---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { getPostsByLang } from "@/i18n/utils";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const allPosts = await getCollection("blog");
  const zhPosts = getPostsByLang(allPosts, "zh");
  const tags = getUniqueTags(zhPosts);

  return tags.flatMap(({ tag }) => {
    const tagPosts = getPostsByTag(zhPosts, tag);
    return paginate(tagPosts, {
      params: { tag },
      pageSize: SITE.postPerPage,
    });
  });
}

const { tag } = Astro.params;
const { page } = Astro.props;
const pageNum = page?.currentPage ?? 1;
const redirectTo = pageNum > 1 ? `/zh/tags/${tag}/${pageNum}/` : `/zh/tags/${tag}/`;
---
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${redirectTo}`} />
    <link rel="canonical" href={redirectTo} />
  </head>
  <body>
    <p>Redirecting to <a href={redirectTo}>{redirectTo}</a>…</p>
  </body>
</html>
