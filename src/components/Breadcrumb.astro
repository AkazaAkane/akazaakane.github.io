---
import { DEFAULT_LOCALE, useTranslations, LOCALES, type Locale } from "@/i18n/ui";

// Remove trailing slash
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Get url array from path, e.g. /zh/posts/why-blog → ["zh", "posts", "why-blog"]
const rawParts = currentUrlPath.split("/").slice(1);

// Detect and strip locale prefix
const lang: Locale = LOCALES.includes(rawParts[0] as Locale) ? (rawParts[0] as Locale) : DEFAULT_LOCALE;
const t = useTranslations(lang);
const breadcrumbList = LOCALES.includes(rawParts[0] as Locale) ? rawParts.slice(1) : rawParts;

// if breadcrumb is [lang] > Posts > 1 etc.
// replace posts with Posts (page N)
if (breadcrumbList[0] === "posts" && breadcrumbList[1]) {
  const pageNum = Number(breadcrumbList[1]);
  if (!isNaN(pageNum)) {
    breadcrumbList.splice(0, 2, t("breadcrumb.postsPage").replace("{n}", String(pageNum)));
  } else if (!breadcrumbList[1]) {
    breadcrumbList.splice(0, 1, t("breadcrumb.postsPage").replace("{n}", "1"));
  }
}

// if breadcrumb is [lang] > Tags > [tag] > [page]
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  breadcrumbList.splice(
    1,
    3,
    `${breadcrumbList[1]} ${Number(breadcrumbList[2]) === 1 ? "" : "(page " + breadcrumbList[2] + ")"}`
  );
}
---

<nav class="app-layout mt-8 mb-1" aria-label="breadcrumb">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href={`/${lang}/`} class="opacity-80">{t("breadcrumb.home")}</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class:list={["capitalize opacity-75", { lowercase: index > 0 }]}
              aria-current="page"
            >
              {decodeURIComponent(breadcrumb)}
            </span>
          </li>
        ) : (
          <li>
            <a href={`/${lang}/${breadcrumb}/`} class="capitalize opacity-70">
              {breadcrumb}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    }
  </ul>
</nav>
